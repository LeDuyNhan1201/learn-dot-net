{
  "Server": {
    "Name": "LearnDotNet",
    "Version": "1.0.0",
    "ApiVersion": "v1.0.0",
    "BasePath": "/api"
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },"OpenTelemetry": {
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    }
  },
  
  "AllowedHosts": "*",

  "AspNetCoreInstrumentation": {
    "RecordException": "true"
  },
  
  "OpenApi": {
    "Title": "Learn DotNet REST APIs",
    "ApiDocs": "learn-dot-net-api-docs",
    "ContactName": "Le Duy Nhan",
    "ContactEmail": "ldnhan.dev@gmail.com",
    "Version": "v1.0.0",
    "ServerUrl": "http://localhost:9999",
    "Description": "This is the APIs documentation for Learn DotNet."
  },
  
  "Observability": {
    "UseTracingExporter": "console",
    "UseMetricsExporter": "console",
    "UseLoggingExporter": "console",
    "HistogramAggregation": "explicit"
  }
}
