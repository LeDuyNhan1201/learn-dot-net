{
  "Server": {
    "Name": "LearnDotNet_Dev"
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "OpenTelemetry": {
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    }
  },

  "Swagger": {
    "Title": "Learn DotNet REST APIs for Development",
    "ApiDocs": "learn-dot-net-api-docs-dev",
    "Description": "This is the APIs documentation for Learn DotNet for Development."
  },
  
  "Observability": {
    "UseTracingExporter": "otlp",
    "UseMetricsExporter": "otlp",
    "UseLogExporter": "otlp",
    "HistogramAggregation": "explicit",
    "Otlp": {
      "Endpoint": "http://localhost:4318"
    }
  }
}
