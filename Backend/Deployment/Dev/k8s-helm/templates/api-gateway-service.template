apiVersion: v1
kind: Service
metadata:
  name: api-gateway
  namespace: {{ .Values.namespace }}
spec:
  selector:
    app: api-gateway
  ports:
    - name: https
      port: {{ .Values.envoy.servicePort }}
      targetPort: https
    - name: admin
      port: {{ .Values.envoy.adminPort }}
      targetPort: admin
