{
  "Server": {
    "Name": "Restaurant_Local"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Authentication": "Information"
    },
    "OpenTelemetry": {
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    }
  },
  "OpenApi": {
    "Title": "Restaurant REST APIs for Local",
    "ApiDocs": "restaurant-api-docs-local",
    "ServerUrl": "https://leduynhan1201.learn-dot-net.dev:60000/restaurant/api",
    "Description": "This is the APIs documentation for Restaurant in Local."
  },
  "Keycloak": {
    "Realm": "learn-dot-net",
    "AuthServerUrl": "https://leduynhan1201.learn-dot-net.dev:60000/auth",
    "Resource": "restaurant-public",
    "Credentials": {
      "Secret": ""
    },
    "Audience": "account",
    "AdditionalAudiences": [
      "restaurant-public"
    ],
    "VerifyTokenAudience": true,
    "SslRequired": "external",
    "ConfidentialPort": 0
  },
  "Authentication": {
    "DefaultScheme": "Bearer",
    "Schemes": {
      "Bearer": {
        "ValidAudiences": [
          "restaurant-public",
          "account"
        ],
        "RequireHttpsMetadata": false,
        "Authority": "https://leduynhan1201.learn-dot-net.dev:60000/auth/realms/learn-dot-net",
        "TokenValidationParameters": {
          "ValidateAudience": true
        }
      }
    }
  }
}
