{
  "Server": {
    "Name": "Restaurant",
    "Version": "1.0.0",
    "BasePath": "/restaurant/api"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    },
    "OpenTelemetry": {
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    }
  },
  "AllowedHosts": "*",
  "AspNetCoreInstrumentation": {
    "RecordException": "true"
  },
  "OpenApi": {
    "Title": "Restaurant REST APIs",
    "ApiDocs": "restaurant-api-docs",
    "ContactName": "Le Duy Nhan",
    "ContactEmail": "ldnhan.dev@gmail.com",
    "Version": "v1.0.0",
    "ServerUrl": "http://localhost:60001/restaurant/api",
    "Description": "This is the APIs documentation for Restaurant."
  },
  "Observability": {
    "UseTracingExporter": "console",
    "UseMetricsExporter": "console",
    "UseLoggingExporter": "console",
    "HistogramAggregation": "explicit"
  },
  "Keycloak": {
    "Audience": "account",
    "VerifyTokenAudience": true,
    "SslRequired": "external"
  },
  "Postgres": {
    "Host": "localhost",
    "Port": 5432,
    "Database": "restaurant_local",
    "Username": "local",
    "Password": "changeit",
    "Ssl": {
      "Enabled": false
    }
  }
}
